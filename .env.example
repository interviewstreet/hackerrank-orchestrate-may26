# OpenRouter API Key (preferred LLM provider for gpt-oss-120b:free)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Claude API Key (fallback if OpenRouter unavailable)
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Data directory (optional, defaults to data/)
DATA_DIR=data

# Quiet mode (set to 1 to disable animations and verbose output)
QUIET=0
