# Copy this file to .env and fill in at least one API key.
# Never commit .env to git.

# Groq (used for llama-3.3-70b-versatile)
GROQ_API_KEY=

# OpenAI (preferred — used for GPT-4o-mini with JSON-mode)
OPENAI_API_KEY=

# Anthropic (fallback — used for Claude Haiku if OPENAI_API_KEY is absent)
ANTHROPIC_API_KEY=

# Ollama (Local free alternative — used if API keys above are absent)
OLLAMA_MODEL=mistral
