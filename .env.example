# Required: OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Free-tier model on OpenRouter (no credits needed, :free suffix = free tier)
# Good free options: meta-llama/llama-3.3-70b-instruct:free, deepseek/deepseek-r1:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Parlant server URL (default; change only if you modify the port)
PARLANT_SERVER_URL=http://localhost:8800

# Parlant data directory (sessions, agent state)
PARLANT_HOME=./parlant_data
