# ---------------------------------------------------------------------------
# Gemini API Configuration
# ---------------------------------------------------------------------------

# Provide multiple keys separated by commas to enable high-throughput 
# parallel processing with round-robin rotation.
# Get keys here: https://aistudio.google.com/app/apikey
GEMINI_API_KEYS=key1,key2,key3,key4,key5,key6,key7

# Fallback individual key (optional)
# GEMINI_API_KEY=your_single_key_here

# ---------------------------------------------------------------------------
# Legacy Configuration (Optional)
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk_your_groq_key_here
