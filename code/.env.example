# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: OpenRouter API key (https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: model backend (default: openrouter)
# Values: openrouter | local_ollama | local_vllm
# MODEL_BACKEND=openrouter

# Optional: local backend URLs (only used when MODEL_BACKEND != openrouter)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# VLLM_BASE_URL=http://localhost:8000/v1

# Optional: Qdrant index storage path (default: <repo_root>/qdrant_db/, next to data/)
# QDRANT_PATH=./qdrant_db

# Optional: path to corpus data directory (default: <repo_root>/data/)
# Set this only if your data lives somewhere other than the repo root's data/ folder.
# DATA_PATH=/path/to/your/data

# Optional: number of corpus chunks to retrieve per query (default: 5)
# RETRIEVAL_TOP_K=5
