# Comma-separated list of Gemini API keys for the thread-safe rotator
# Essential for parallel batch processing to avoid 429 Rate Limits
GEMINI_API_KEYS=key1,key2,key3

# (Optional but Recommended) Azure OpenAI credentials for primary cascade
AZURE_OPENAI_API_KEY=your_azure_key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name

# (Optional) Groq API key for final fallback cascade
GROQ_API_KEY=your_groq_key
